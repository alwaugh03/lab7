<div class="container mt-4">
  <h1 class="mb-4">Vets</h1>

  <table class="table table-striped table-bordered">
    <thead class="table-dark">
      <tr>
        <th>Full Name</th>
        <th>Email</th>
        <th>Specialization</th>
      </tr>
    </thead>

    <tbody>
      <% @vets.each do |vet| %>
        <tr>
          <td>
            <%= link_to "#{vet.first_name} #{vet.last_name}", vet_path(vet), class: "text-decoration-none" %>
          </td>
          <td><%= vet.email %></td>
          <td><%= vet.specialization %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
