<div class="container mt-4">
  <h1 class="mb-4">Owners</h1>
  <%= link_to "New Owner", new_owner_path, class: "btn btn-primary mb-3" %>
  <table class="table table-striped table-bordered">
    <thead class="table-dark">
      <tr>
        <th>Full Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Number of Pets</th>
      </tr>
    </thead>

    <tbody>
      <% @owners.each do |owner| %>
        <tr>
          <td>
            <%= link_to "#{owner.first_name} #{owner.last_name}", owner_path(owner), class: "text-decoration-none" %>
          </td>
          <td><%= owner.email %></td>
          <td><%= owner.phone %></td>
          <td><%= owner.pets.size %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
